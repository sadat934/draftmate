{
  "name": "draftmate",
  "version": "0.1.0",
  "private": true,
  "description": "DraftMate Microsoft Word add-in for AI-assisted writing, East African payments, and BYO AI keys.",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:webpack\"",
    "start:server": "node server/index.js",
    "start:webpack": "webpack serve --mode development",
    "build": "webpack --mode production",
    "vercel-build": "webpack --mode production",
    "check": "node scripts/check-syntax.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "babel-loader": "^10.1.1",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "office-addin-dev-certs": "^2.0.9",
    "style-loader": "^4.0.0",
    "webpack": "^5.107.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "regenerator-runtime": "^0.14.1"
  }
}
